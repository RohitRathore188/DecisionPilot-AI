# DecisionPilot AI - Backend Environment Variables Example

# FastAPI Configurations
PROJECT_NAME="DecisionPilot AI"
API_V1_STR="/api/v1"

# Allowed CORS origins (comma-separated list)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Integration Configurations
# Obtain these from your Supabase Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-or-anon-key

# Supabase JWT Secret
# Obtain this from Supabase Project Settings -> API -> JWT Settings -> JWT Secret
# IMPORTANT: This is required to verify bearer tokens locally in FastAPI.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-string

# Gemini API Integration Configuration
# Obtain this from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your-gemini-api-key-string
